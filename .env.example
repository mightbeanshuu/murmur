OPENROUTER_API_KEY=

# Production event stream. Every event has a versioned envelope, ordered per run,
# and is published with all-replica acknowledgement when Kafka is configured.
KAFKA_BROKERS=
KAFKA_CLIENT_ID=murmur-web
KAFKA_SWARM_EVENTS_TOPIC=murmur.swarm.events
KAFKA_ALLOW_AUTO_TOPIC_CREATION=0
KAFKA_SSL=0
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Redis owns distributed rate limits plus expiring run sessions and an append-only
# event stream. When unset, local development still works without infrastructure.
REDIS_URL=
MURMUR_RUNS_PER_WINDOW=20
MURMUR_RUN_WINDOW_SECONDS=3600
MURMUR_MODEL_CALLS_PER_WINDOW=120
MURMUR_MODEL_WINDOW_SECONDS=3600
MURMUR_STRICT_REDIS_RATE_LIMIT=0
MURMUR_RUN_SESSION_TTL_SECONDS=86400
MURMUR_RUN_EVENT_STREAM_MAX_LENGTH=10000
# Set to 1 to fail a swarm run when configured Kafka or Redis delivery fails.
MURMUR_STRICT_EVENT_DELIVERY=0
