OPENROUTER_API_KEY=

# Optional production event stream. When set, every swarm event is published to Kafka
# in addition to the local SSE stream used by the browser.
KAFKA_BROKERS=
KAFKA_CLIENT_ID=murmur-web
KAFKA_SWARM_EVENTS_TOPIC=murmur.swarm.events
KAFKA_ALLOW_AUTO_TOPIC_CREATION=0
KAFKA_SSL=0
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Optional distributed rate limiting. When REDIS_URL is unset, rate limiting is disabled
# so local development still works without infrastructure.
REDIS_URL=
MURMUR_RUNS_PER_WINDOW=20
MURMUR_RUN_WINDOW_SECONDS=3600
MURMUR_MODEL_CALLS_PER_WINDOW=120
MURMUR_MODEL_WINDOW_SECONDS=3600
MURMUR_STRICT_REDIS_RATE_LIMIT=0
