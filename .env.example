OPENROUTER_API_KEY=

# Better Auth + PostgreSQL. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://murmur:murmur@localhost:5432/murmur
AUTH_DB_POOL_SIZE=10

# Stripe Pro subscriptions. Create one recurring Price and configure a webhook
# for checkout.session.completed and customer.subscription.* events.
APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIGURATION_ID=

# Use `temporal` to move long runs out of the HTTP process. `direct` keeps the
# original in-process path available for debugging and constrained deployments.
MURMUR_EXECUTION_MODE=temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=murmur-swarm

# Required Kafka event stream. `pnpm infra:up` exposes the local broker here.
# Production should use managed brokers with TLS/SASL and replication >= 3.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=murmur-web
KAFKA_SWARM_EVENTS_TOPIC=murmur.swarm.events
# Local Compose has no TLS. Hosted production Kafka must set this to 1 and add
# its SASL username/password below.
KAFKA_SSL=0
# Optional for hosted brokers that use a private/project CA. Vercel accepts the
# full multiline PEM value as an encrypted environment variable.
KAFKA_CA_CERT=
KAFKA_SASL_MECHANISM=plain
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_CONNECTION_TIMEOUT_MS=5000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_RETRY_COUNT=8
KAFKA_LOG_LEVEL=error

# Required Redis state. Use rediss:// for TLS-enabled managed Redis in production.
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=3000
MURMUR_FREE_RUNS_PER_WINDOW=10
MURMUR_PRO_RUNS_PER_WINDOW=100
MURMUR_RUN_WINDOW_SECONDS=3600
MURMUR_MODEL_CALLS_PER_WINDOW=120
MURMUR_MODEL_WINDOW_SECONDS=3600
MURMUR_RUN_SESSION_TTL_SECONDS=86400
MURMUR_RUN_EVENT_STREAM_MAX_LENGTH=10000
MURMUR_INFRA_HEALTH_CACHE_MS=5000
