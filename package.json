{
  "name": "murmur",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "tsx scripts/vercel-build.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "auth:migrate": "tsx scripts/migrate-auth.ts",
    "billing:migrate": "tsx scripts/migrate-billing.ts",
    "mcp:migrate": "tsx scripts/migrate-mcp.ts",
    "db:migrate": "pnpm auth:migrate && pnpm billing:migrate && pnpm mcp:migrate",
    "temporal:worker": "tsx src/temporal/worker.ts",
    "infra:up": "docker-compose up -d --wait",
    "infra:down": "docker-compose down",
    "infra:reset": "docker-compose down -v",
    "infra:logs": "docker-compose logs -f kafka redis postgres temporal telemetry",
    "infra:ps": "docker-compose ps",
    "infra:topic": "docker-compose exec kafka /opt/kafka/bin/kafka-topics.sh --bootstrap-server localhost:9092 --describe --topic murmur.swarm.events",
    "infra:full": "docker-compose --profile app up -d --build --wait"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@next/env": "16.2.7",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@temporalio/activity": "^1.20.3",
    "@temporalio/client": "^1.20.3",
    "@temporalio/worker": "^1.20.3",
    "@temporalio/workflow": "^1.20.3",
    "ai": "^6.0.195",
    "animejs": "4.5.0",
    "better-auth": "^1.6.23",
    "cloudinary": "^2.10.0",
    "ioredis": "^5.8.2",
    "kafkajs": "^2.2.4",
    "next": "16.2.7",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.3.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
